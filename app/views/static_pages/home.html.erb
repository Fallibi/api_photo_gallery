<div class="container mx-auto px-4 py-8">
  <h1 class="text-4xl font-bold text-center mb-4">Pexels Collection Viewer</h1>
  <p class="text-center text-gray-600 mb-8">
    Enter a Pexels collection ID to view its photos. (e.g., "tnqakbk")
  </p>

  <%= turbo_frame_tag "gallery" do %>
    
    <%= form_with url: root_path, method: :get, class: "mb-8 flex justify-center" do |form| %>
      <div class="flex items-center border-b border-b-2 border-teal-500 py-2">
        <%= form.text_field :collection_id, 
                             value: params[:collection_id],
                             class: "appearance-none bg-transparent border-none w-full text-gray-700 mr-3 py-1 px-2 leading-tight focus:outline-none", 
                             placeholder: "Enter Collection ID" %>
        <%= form.submit "Fetch Photos", class: "flex-shrink-0 bg-teal-500 hover:bg-teal-700 border-teal-500 hover:border-teal-700 text-sm border-4 text-white py-1 px-2 rounded cursor-pointer" %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative text-center mb-4" role="alert">
        <span class="block sm:inline"><%= flash[:alert] %></span>
      </div>
    <% end %>

    <% if @photos %>
      <% if @photos.empty? && params[:collection_id].present? %>
        <p class="text-center text-gray-500">No photos found for this collection, or the collection is invalid.</p>
      <% end %>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @photos.each do |photo| %>
          <div class="overflow-hidden rounded-lg shadow-lg">
            <% if photo.type == "Photo" %>
              <%# --- FINAL FIX BASED ON DEBUG DATA --- %>
              <%# The photographer's name is at photo.user.name %>
              <img src="<%= photo.src['medium'] %>" alt="Photo by <%= photo.user.name %>" class="w-full h-auto object-cover">
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

  <% end %>
</div>

<script src="https://cdn.tailwindcss.com"></script>